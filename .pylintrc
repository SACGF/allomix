[MAIN]
# Match ruff config (pyproject.toml)
py-version = 3.10
jobs = 0

[FORMAT]
max-line-length = 100

[MESSAGES CONTROL]
# Disable rules that are either:
#   - already covered by ruff (formatting / import order),
#   - noisy for a research/scripts codebase (docstrings on every test func, complexity counts),
#   - or by-design here (sys.path shim before imports in standalone scripts).
disable =
    # Style covered by ruff format
    line-too-long,
    # Docstring policy: required on public modules/funcs in src/, but pylint
    # has no granular control. Disable globally; reviewers enforce in src/.
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    # sys.path.insert before importing allomix is intentional in standalone
    # scripts (paper/scripts and scripts/ are runnable from a checkout
    # without installing the package).
    wrong-import-position,
    # Complexity heuristics. Validation/figure scripts and dataclasses
    # legitimately exceed these; we'd rather see real bugs than refactor
    # noise.
    too-many-locals,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-statements,
    too-many-branches,
    too-many-instance-attributes,
    too-many-nested-blocks,
    too-many-return-statements,
    too-many-lines,
    too-few-public-methods,
    # R0801 false-positive prone: shared CLI flag tuples and CSV header
    # dicts trip it without indicating real duplication.
    duplicate-code,
    # Stylistic preferences we don't share.
    use-dict-literal,
    use-implicit-booleaness-not-comparison,
    no-else-return,

[TYPECHECK]
# matplotlib.cm dynamically registers colormaps; pylint can't see them.
generated-members = matplotlib.cm.*
