"""Multi-patient genotyping + admixture pileup pipeline for allomix.

One CSV per patient with columns ``sample_id,bam_filename,sample_type``
(values ``HOST``, ``DONOR``, ``ADMIX``). All CSVs in
``samples_csv_dir`` (default ``pipeline/sample_csvs``) are processed in
one DAG so HaplotypeCaller / pileup jobs across patients run in parallel
under a single ``snakemake --cores N`` invocation.

Two phases share the DAG (per patient):

    Phase 1 — GATK joint-call HOST + DONOR BAMs
        HaplotypeCaller (GVCF) -> CombineGVCFs -> GenotypeGVCFs
        Output: <patient>.vcf.gz  (panel sites + reliable host/donor GTs)

    Phase 2 — Forced bcftools mpileup on ADMIX BAMs at the phase-1 sites
        Per admix sample: bcftools mpileup -a FORMAT/AD,FORMAT/DP -R panel
                          | bcftools call -m -C alleles -T panel.targets
        Then bcftools merge across admix samples.
        Output: <patient>.admix.vcf.gz  (raw AD at every panel site)

Why this split: GATK is the right tool for genotyping the reference
samples (we only need GT there). It is the wrong tool for the admix AD,
because HaplotypeCaller -ERC GVCF strips minority ALT reads from
FORMAT/AD at hom-ref blocks (local reassembly only tracks the called
allele). That is exactly the signal that low-fraction host detection
depends on. ``bcftools mpileup`` preserves raw per-allele counts;
``bcftools call -C alleles`` then assigns a GT at every panel site
using only the panel's known REF/ALT pair as candidates.

Usage (from repo root):
    # All patients in pipeline/sample_csvs/
    snakemake -s pipeline/Snakefile --configfile pipeline/config.yaml --cores 16

    # Single-patient run (override the directory with one CSV)
    snakemake -s pipeline/Snakefile \\
        --config ref=/path/hg38.fa samples_csv=patientX.csv --cores 8
"""

import csv
import glob
import os
import re


# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

configfile: os.path.join(workflow.basedir, "config.yaml")

REF = config["ref"]
OUTPUT_DIR = config.get("output_dir", "output/joint_call")

# Patient discovery — either a directory of per-patient CSVs (multi-patient
# DAG) or a single CSV path (back-compat for one-shot runs).
SAMPLES_CSV = config.get("samples_csv")
SAMPLES_CSV_DIR = config.get(
    "samples_csv_dir", os.path.join(workflow.basedir, "sample_csvs")
)

# Phase 1 (GATK)
GATK = config.get("gatk", "gatk")
JAVA_MEM = config.get("java_mem", "8g")
INTERVALS = config.get("intervals", None)
# Optional fixed panel of (CHROM,POS,REF,ALT) sites. When set, GenotypeGVCFs
# forces a genotype at every panel site (--force-output-intervals) and the
# panel VCF is used as -L intervals throughout phase 1, so the per-patient
# panel size is constant regardless of how many variants GATK discovers in
# HOST+DONOR alone. The main payoff is a marginal informative marker that
# falls below the calling QUAL threshold in a small 2-sample joint call: forced
# output pins its genotype back. See doc/joint_calling.md. Same VCF is then
# used by phase 2.
PANEL_ALLELES_VCF = config.get("panel_alleles_vcf", None)
if PANEL_ALLELES_VCF:
    # Panel VCF overrides any intervals BED — using both would just mask
    # panel sites that fall outside the BED.
    INTERVALS_ARG = f"-L {PANEL_ALLELES_VCF}"
    _intervals_tag = (
        f".{os.path.splitext(os.path.basename(PANEL_ALLELES_VCF))[0].removesuffix('.vcf')}"
    )
else:
    INTERVALS_ARG = f"-L {INTERVALS}" if INTERVALS else ""
    _intervals_tag = (
        f".{os.path.splitext(os.path.basename(INTERVALS))[0]}" if INTERVALS else ""
    )
# GenotypeGVCFs has no --alleles option (that lives on HaplotypeCaller). The
# tool's own mechanism for "emit a genotype at these sites even if non-variant
# in the samples" is --force-output-intervals. It is mutually exclusive with
# --include-non-variant-sites (the all-sites variant): force-output already
# genotypes the given panel sites whether or not they are variant, so we use it
# alone. See doc/joint_calling.md for why we force every panel site.
GENOTYPE_GVCFS_ALLELES_ARG = (
    f"--force-output-intervals {PANEL_ALLELES_VCF}" if PANEL_ALLELES_VCF else ""
)

# Phase 2 (bcftools mpileup)
BCFTOOLS = config.get("bcftools", "bcftools")
MAX_DEPTH = config.get("max_depth", 100000)
MIN_MAPQ = config.get("min_mapq", 20)
MIN_BASEQ = config.get("min_baseq", 20)
READ_FILTERS = config.get("read_filters", "UNMAP,SECONDARY,QCFAIL,DUP")

# Shared
TABIX = config.get("tabix", "tabix")
BGZIP = config.get("bgzip", "bgzip")


def _discover_patients():
    """Map {patient_id: csv_path} from samples_csv (single) or samples_csv_dir."""
    if SAMPLES_CSV:
        pid = os.path.splitext(os.path.basename(SAMPLES_CSV))[0]
        return {pid: SAMPLES_CSV}
    paths = sorted(glob.glob(os.path.join(SAMPLES_CSV_DIR, "*.csv")))
    if not paths:
        raise ValueError(
            f"No CSV files found in {SAMPLES_CSV_DIR}. "
            f"Set samples_csv_dir or samples_csv in config / --config."
        )
    return {os.path.splitext(os.path.basename(p))[0]: p for p in paths}


PATIENTS = _discover_patients()

# Cache to avoid re-parsing each CSV on every input function call.
_samples_cache: dict[str, tuple[dict[str, str], dict[str, str]]] = {}


def _patient_samples(patient):
    """Return (ref_samples, admix_samples) dicts for ``patient``."""
    if patient not in _samples_cache:
        csv_path = PATIENTS[patient]
        ref, admix = {}, {}
        with open(csv_path) as f:
            reader = csv.DictReader(f)
            if "sample_type" not in (reader.fieldnames or []):
                raise ValueError(
                    f"{csv_path} is missing the required 'sample_type' "
                    f"column (expected values: HOST, DONOR, ADMIX)"
                )
            for row in reader:
                stype = row["sample_type"].strip().upper()
                sid = row["sample_id"]
                bam = row["bam_filename"]
                if stype in ("HOST", "DONOR"):
                    ref[sid] = bam
                elif stype == "ADMIX":
                    admix[sid] = bam
                else:
                    raise ValueError(
                        f"{csv_path}: unknown sample_type {stype!r} for "
                        f"sample {sid}"
                    )
        if not ref:
            raise ValueError(
                f"{csv_path} has no HOST or DONOR rows; phase 1 cannot run"
            )
        _samples_cache[patient] = (ref, admix)
    return _samples_cache[patient]


def _ref_samples(patient):
    return _patient_samples(patient)[0]


def _admix_samples(patient):
    return _patient_samples(patient)[1]


def _bam_for_sample(patient, sample):
    ref, admix = _patient_samples(patient)
    if sample in ref:
        return ref[sample]
    return admix[sample]


# Eagerly validate every CSV at parse time so errors surface up-front
# rather than mid-DAG. Also lets us decide which patients have admix work.
for _p in PATIENTS:
    _patient_samples(_p)


# ---------------------------------------------------------------------------
# Output paths (all keyed on {patient})
# ---------------------------------------------------------------------------

# Final outputs — kept at the top-level OUTPUT_DIR so existing per-patient
# VCFs from earlier single-patient runs are recognised and reused.
def _joint_vcf(patient):
    return os.path.join(OUTPUT_DIR, f"{patient}{_intervals_tag}.vcf.gz")


def _admix_vcf(patient):
    return os.path.join(OUTPUT_DIR, f"{patient}.admix.vcf.gz")


# Per-patient intermediates live under <OUTPUT_DIR>/<patient>/ to avoid
# cross-patient collisions on shared filenames (combined.g.vcf.gz,
# admix/per_sample/...).
JOINT_VCF_TPL = os.path.join(OUTPUT_DIR, f"{{patient}}{_intervals_tag}.vcf.gz")
ADMIX_VCF_TPL = os.path.join(OUTPUT_DIR, "{patient}.admix.vcf.gz")
GVCF_TPL = os.path.join(OUTPUT_DIR, "gvcfs", "{sample}.g.vcf.gz")
COMBINED_GVCF_TPL = os.path.join(OUTPUT_DIR, "{patient}", "combined.g.vcf.gz")
PANEL_TSV_TPL = os.path.join(OUTPUT_DIR, "{patient}", "admix", "targets.tsv.gz")
PER_SAMPLE_ADMIX_TPL = os.path.join(
    OUTPUT_DIR, "{patient}", "admix", "per_sample", "{sample}.vcf.gz"
)


# ---------------------------------------------------------------------------
# Top-level target
# ---------------------------------------------------------------------------

def _all_targets():
    out = []
    for p in PATIENTS:
        out.append(_joint_vcf(p))
        if _admix_samples(p):
            out.append(_admix_vcf(p))
    return out


rule all:
    input:
        _all_targets(),


# Restrict wildcards so {patient}/{sample} cannot match path separators
# or partial intermediate filenames (e.g. "combined.g") — otherwise
# Snakemake recurses on shared path components.
wildcard_constraints:
    patient="|".join(re.escape(p) for p in PATIENTS),
    sample=r"[^/]+",


# ---------------------------------------------------------------------------
# Phase 1: GATK HOST + DONOR joint genotyping (per patient)
# ---------------------------------------------------------------------------

# GVCFs are keyed on sample only (sample IDs are globally unique across
# patient CSVs). This lets a sample shared between two patient CSVs reuse
# its GVCF and avoids needless reruns of cached single-patient outputs.
rule haplotype_caller:
    """Run GATK HaplotypeCaller in GVCF mode on a single HOST/DONOR sample."""
    input:
        bam=lambda wc: next(
            bam
            for p in PATIENTS
            for sid, bam in _ref_samples(p).items()
            if sid == wc.sample
        ),
        ref=REF,
    output:
        gvcf=GVCF_TPL,
        tbi=GVCF_TPL + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "haplotype_caller", "{sample}.log"),
    threads: 4
    params:
        gatk=GATK,
        tabix=TABIX,
        java_mem=JAVA_MEM,
        intervals_arg=INTERVALS_ARG,
    shell:
        """
        {params.gatk} --java-options '-Xmx{params.java_mem}' HaplotypeCaller \
            -R {input.ref} \
            -I {input.bam} \
            -ERC GVCF \
            -O {output.gvcf} \
            --native-pair-hmm-threads {threads} \
            {params.intervals_arg} \
            2>&1 | tee {log}
        {params.tabix} -f {output.gvcf}
        """


rule combine_gvcfs:
    """Merge per-sample GVCFs into a single combined GVCF for one patient.

    No -L here on purpose. The input GVCFs are already restricted to the panel
    region by haplotype_caller's -L, so CombineGVCFs needs no interval
    restriction. Passing -L here triggers a GATK bug: with a spanning or
    multiallelic <NON_REF> block straddling panel sites, the interval-restricted
    endPreviousStates flush can write records out of coordinate order ("Features
    added out of order"), which the tabix index writer rejects. genotype_gvcfs
    still applies -L + force-output, so the final panel VCF is unchanged.
    """
    input:
        gvcfs=lambda wc: expand(GVCF_TPL, sample=list(_ref_samples(wc.patient))),
        ref=REF,
    output:
        combined=COMBINED_GVCF_TPL,
        tbi=COMBINED_GVCF_TPL + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "combine_gvcfs", "{patient}.log"),
    params:
        gatk=GATK,
        tabix=TABIX,
        java_mem=JAVA_MEM,
        gvcf_args=lambda wc, input: " ".join(f"-V {g}" for g in input.gvcfs),
    shell:
        """
        {params.gatk} --java-options '-Xmx{params.java_mem}' CombineGVCFs \
            -R {input.ref} \
            {params.gvcf_args} \
            -O {output.combined} \
            2>&1 | tee {log}
        {params.tabix} -f {output.combined}
        """


rule genotype_gvcfs:
    """Joint-genotype the combined GVCF to produce one patient's panel VCF."""
    input:
        combined=COMBINED_GVCF_TPL,
        ref=REF,
    output:
        vcf=JOINT_VCF_TPL,
        tbi=JOINT_VCF_TPL + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "genotype_gvcfs", "{patient}.log"),
    params:
        gatk=GATK,
        java_mem=JAVA_MEM,
        intervals_arg=INTERVALS_ARG,
        alleles_arg=GENOTYPE_GVCFS_ALLELES_ARG,
    shell:
        """
        {params.gatk} --java-options '-Xmx{params.java_mem}' GenotypeGVCFs \
            -R {input.ref} \
            -V {input.combined} \
            -O {output.vcf} \
            --verbosity ERROR \
            {params.intervals_arg} \
            {params.alleles_arg} \
            2>&1 | tee {log}
        """


# ---------------------------------------------------------------------------
# Phase 2: forced bcftools mpileup on ADMIX samples at phase-1 panel sites
# ---------------------------------------------------------------------------

rule panel_tsv:
    """Extract (CHROM,POS,REF,ALT) targets file from one patient's panel VCF.

    Used by ``bcftools call -C alleles -T`` to force a GT at every panel
    position with the panel's exact REF/ALT pair as the only candidates.
    """
    input:
        vcf=JOINT_VCF_TPL,
    output:
        tsv=PANEL_TSV_TPL,
        tbi=PANEL_TSV_TPL + ".tbi",
    params:
        bcftools=BCFTOOLS,
        bgzip=BGZIP,
        tabix=TABIX,
    shell:
        """
        {params.bcftools} query -f '%CHROM\\t%POS\\t%REF,%ALT\\n' {input.vcf} \
            | {params.bgzip} -c > {output.tsv}
        {params.tabix} -f -s1 -b2 -e2 {output.tsv}
        """


rule pileup_admix:
    """Raw pileup + constrained-allele genotyping for one admixture sample.

    ``mpileup -a FORMAT/AD,FORMAT/DP`` reports raw REF/ALT base counts at
    every panel position — no local reassembly, no minority-ALT stripping.
    ``call -m -C alleles -T panel_tsv`` then assigns a GT at each site
    using only the panel's known REF/ALT as candidates, so the output
    covers every panel site regardless of whether the ALT was observed.
    """
    input:
        bam=lambda wc: _bam_for_sample(wc.patient, wc.sample),
        ref=REF,
        targets=PANEL_TSV_TPL,
        targets_tbi=PANEL_TSV_TPL + ".tbi",
        panel=JOINT_VCF_TPL,
    output:
        vcf=PER_SAMPLE_ADMIX_TPL,
        tbi=PER_SAMPLE_ADMIX_TPL + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "pileup_admix", "{patient}", "{sample}.log"),
    threads: 2
    params:
        bcftools=BCFTOOLS,
        tabix=TABIX,
        max_depth=MAX_DEPTH,
        min_mapq=MIN_MAPQ,
        min_baseq=MIN_BASEQ,
        read_filters=READ_FILTERS,
    shell:
        """
        {params.bcftools} mpileup \
            -f {input.ref} \
            -R {input.panel} \
            -a FORMAT/AD,FORMAT/DP \
            -d {params.max_depth} \
            -q {params.min_mapq} \
            -Q {params.min_baseq} \
            --ff {params.read_filters} \
            --threads {threads} \
            {input.bam} 2> {log} \
        | {params.bcftools} call \
            -m \
            -C alleles \
            -T {input.targets} \
            -Oz -o {output.vcf} 2>> {log}
        {params.tabix} -f {output.vcf}
        """


rule merge_admix:
    """Merge per-admix-sample VCFs into one multi-sample admixture VCF per patient.

    All per-sample VCFs cover every panel site (constrained calling
    guarantees this), so the merge has no missing-sample positions.
    """
    input:
        vcfs=lambda wc: expand(
            PER_SAMPLE_ADMIX_TPL,
            patient=[wc.patient],
            sample=list(_admix_samples(wc.patient)),
        ),
        tbis=lambda wc: expand(
            PER_SAMPLE_ADMIX_TPL + ".tbi",
            patient=[wc.patient],
            sample=list(_admix_samples(wc.patient)),
        ),
    output:
        vcf=ADMIX_VCF_TPL,
        tbi=ADMIX_VCF_TPL + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "merge_admix", "{patient}.log"),
    threads: 4
    params:
        bcftools=BCFTOOLS,
        tabix=TABIX,
    shell:
        """
        {params.bcftools} merge \
            --threads {threads} \
            --force-single \
            -m all \
            -Oz -o {output.vcf} \
            {input.vcfs} 2>&1 | tee {log}
        {params.tabix} -f {output.vcf}
        """


# ---------------------------------------------------------------------------
# Cleanup
# ---------------------------------------------------------------------------

rule clean:
    """Remove all pipeline output."""
    shell:
        f"rm -rf {OUTPUT_DIR}/"
