"""Multi-patient genotyping + admixture pileup pipeline for allomix.

One CSV per patient with columns ``sample_id,bam_filename,sample_type``
(values ``HOST``, ``DONOR``, ``ADMIX``). All CSVs in
``samples_csv_dir`` (default ``pipeline/sample_csvs``) are processed in
one DAG so HaplotypeCaller / pileup jobs across patients run in parallel
under a single ``snakemake --cores N`` invocation.

Two phases share the DAG (per patient), with an optional alignment phase in
front of them:

    Phase 0 (optional) — bwa mem align FASTQ -> sorted, indexed BAM
        Active only when `fastq_dir` is set in config. Aligns
        <fastq_dir>/<run>.<fastq_suffix> -> <bam_dir>/<run>.<bam_suffix> (the
        CSV bam_filename paths), stamping read-group SM with the sample_id.
        Deployments that already have BAMs leave fastq_dir unset and skip this.

    Phase 1 — GATK joint-call HOST + DONOR BAMs
        HaplotypeCaller (GVCF) -> CombineGVCFs -> GenotypeGVCFs
        Output: <patient>.vcf.gz  (panel sites + reliable host/donor GTs)

    Phase 2 — Forced bcftools mpileup on ADMIX BAMs at the phase-1 sites
        Per admix sample: bcftools mpileup -a FORMAT/AD,FORMAT/DP -R panel
                          | bcftools call -m -C alleles -T panel.targets
        Then bcftools merge across admix samples.
        Output: <patient>.admix.vcf.gz  (raw AD at every panel site)

    Run metadata — stamp each admix sample's flowcell+lane into the VCF (issue #12)
        Per patient (when it has admix samples): read the sequencing run unit
        from each BAM, flag admix samples that share one with the host (the
        index-hopping risk allomix cannot see from the VCF alone), and inject the
        result as ``##allomixRunUnit`` header lines on the admix VCF during the
        merge. allomix reads them straight back from the header. Optional: when
        no run unit is recoverable (e.g. SRA-renamed reads), nothing is added.

Why this split: GATK is the right tool for genotyping the reference
samples (we only need GT there). It is the wrong tool for the admix AD,
because HaplotypeCaller -ERC GVCF strips minority ALT reads from
FORMAT/AD at hom-ref blocks (local reassembly only tracks the called
allele). That is exactly the signal that low-fraction host detection
depends on. ``bcftools mpileup`` preserves raw per-allele counts;
``bcftools call -C alleles`` then assigns a GT at every panel site
using only the panel's known REF/ALT pair as candidates.

Config is two-layer (issue #30): pipeline/tools.yaml holds per-machine tool
paths and resources (set up once per machine); pipeline/config.yaml holds the
per-run settings (reference, panel, sample CSVs, output, mpileup params). Both
load as defaults; --configfile and --config override on top.

Usage (from repo root):
    # First time on a machine: check the tools in tools.yaml are runnable
    snakemake -s pipeline/Snakefile validate_tools

    # All patients in pipeline/sample_csvs/
    snakemake -s pipeline/Snakefile --configfile pipeline/config.yaml --cores 16

    # Single-patient run (override the directory with one CSV)
    snakemake -s pipeline/Snakefile \\
        --config ref=/path/hg38.fa samples_csv=patientX.csv --cores 8
"""

import csv
import glob
import os
import re
import sys


# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

# Two-layer config (issue #30): tools.yaml holds per-machine tool paths and
# resources; config.yaml holds the per-run settings. Both load as defaults here
# (tools first, so run config and any --configfile / --config override on top).
configfile: os.path.join(workflow.basedir, "tools.yaml")
configfile: os.path.join(workflow.basedir, "config.yaml")

REF = config["ref"]
OUTPUT_DIR = config.get("output_dir", "output/genotypes")

# Patient discovery — either a directory of per-patient CSVs (multi-patient
# DAG) or a single CSV path (back-compat for one-shot runs).
SAMPLES_CSV = config.get("samples_csv")
SAMPLES_CSV_DIR = config.get(
    "samples_csv_dir", os.path.join(workflow.basedir, "sample_csvs")
)

# Phase 1 (GATK)
GATK = config.get("gatk", "gatk")
JAVA_MEM = config.get("java_mem", "8g")
INTERVALS = config.get("intervals", None)
if not INTERVALS:
    raise ValueError(
        "`intervals:` is required — set it to the capture-panel BED. "
        "Running GATK genome-wide on every WGS SNP is not a supported mode."
    )
INTERVALS_ARG = f"-L {INTERVALS}"
_intervals_tag = f".{os.path.splitext(os.path.basename(INTERVALS))[0]}"
# Optional fixed panel of (CHROM,POS,REF,ALT) sites. When set, GenotypeGVCFs
# uses --force-output-intervals to pin a genotype at every panel site on top
# of whatever GATK discovers in the `intervals` BED. The payoff is a marginal
# informative marker that falls below the calling QUAL threshold in a small
# 2-sample joint call: forced output pins its genotype back. See
# docs/joint_calling.md. Same VCF is then used by phase 2.
PANEL_ALLELES_VCF = config.get("panel_alleles_vcf", None)
# GenotypeGVCFs has no --alleles option (that lives on HaplotypeCaller). The
# tool's own mechanism for "emit a genotype at these sites even if non-variant
# in the samples" is --force-output-intervals. It is mutually exclusive with
# --include-non-variant-sites (the all-sites variant): force-output already
# genotypes the given panel sites whether or not they are variant, so we use it
# alone. See docs/joint_calling.md for why we force every panel site.
GENOTYPE_GVCFS_ALLELES_ARG = (
    f"--force-output-intervals {PANEL_ALLELES_VCF}" if PANEL_ALLELES_VCF else ""
)

# Phase 2 (bcftools mpileup)
BCFTOOLS = config.get("bcftools", "bcftools")
MAX_DEPTH = config.get("max_depth", 100000)
MIN_MAPQ = config.get("min_mapq", 20)
MIN_BASEQ = config.get("min_baseq", 20)
READ_FILTERS = config.get("read_filters", "UNMAP,SECONDARY,QCFAIL,DUP")

# Shared
TABIX = config.get("tabix", "tabix")
BGZIP = config.get("bgzip", "bgzip")
# Interpreter for the pipeline helper scripts (pure stdlib, no allomix import).
# Defaults to the Python running Snakemake, which is always a valid interpreter.
PYTHON = config.get("python", sys.executable)

# Optional phase 1b — per-patient empirical error table (host-presence background).
# A raw bcftools mpileup of the HOST/DONOR BAMs at the panel sites plus one
# force-called background position per amplicon (the BED-interval midpoints)
# feeds `allomix estimate-errors`, giving a per-site, both-direction error table.
# GATK cannot supply this: its GVCF reassembly strips minority ALT reads at
# hom-ref blocks, the exact ref->alt signal we need (see docs/joint_calling.md).
# Off would drop the error_table targets entirely. Needs `allomix` on PATH.
BUILD_ERROR_TABLE = config.get("build_error_table", True)
ALLOMIX = config.get("allomix", "allomix")
# One single-base background position per panel interval, derived from INTERVALS.
MIDPOINTS_BED = os.path.join(OUTPUT_DIR, f"midpoints{_intervals_tag}.bed")

# Optional alignment (FASTQ -> BAM) with bwa mem. Active only when `fastq_dir`
# is set; otherwise the bam_filename paths in the CSVs are treated as
# pre-aligned inputs (the default for deployments that already have BAMs).
# When active, each <fastq_dir>/<run>.<fastq_suffix> is aligned to
# <bam_dir>/<run>.<bam_suffix>, which must equal the CSV bam_filename paths.
FASTQ_DIR = config.get("fastq_dir") or None
BWA = config.get("bwa", "bwa")
SAMTOOLS = config.get("samtools", "samtools")
BAM_DIR = config.get("bam_dir") or None
BAM_SUFFIX = config.get("bam_suffix", "hg38.bam")
FASTQ_SUFFIX = config.get("fastq_suffix", "fastq.gz")
ALIGN_THREADS = config.get("align_threads", 8)


def _discover_patients():
    """Map {patient_id: csv_path} from samples_csv (single) or samples_csv_dir."""
    if SAMPLES_CSV:
        pid = os.path.splitext(os.path.basename(SAMPLES_CSV))[0]
        return {pid: SAMPLES_CSV}
    paths = sorted(glob.glob(os.path.join(SAMPLES_CSV_DIR, "*.csv")))
    if not paths:
        raise ValueError(
            f"No CSV files found in {SAMPLES_CSV_DIR}. "
            f"Set samples_csv_dir or samples_csv in config / --config."
        )
    return {os.path.splitext(os.path.basename(p))[0]: p for p in paths}


PATIENTS = _discover_patients()

# Cache to avoid re-parsing each CSV on every input function call.
_samples_cache: dict[str, tuple[dict[str, str], dict[str, str]]] = {}


def _patient_samples(patient):
    """Return (ref_samples, admix_samples) dicts for ``patient``."""
    if patient not in _samples_cache:
        csv_path = PATIENTS[patient]
        ref, admix = {}, {}
        with open(csv_path) as f:
            reader = csv.DictReader(f)
            if "sample_type" not in (reader.fieldnames or []):
                raise ValueError(
                    f"{csv_path} is missing the required 'sample_type' "
                    f"column (expected values: HOST, DONOR, ADMIX)"
                )
            for row in reader:
                stype = row["sample_type"].strip().upper()
                sid = row["sample_id"]
                bam = row["bam_filename"]
                if stype in ("HOST", "DONOR"):
                    ref[sid] = bam
                elif stype == "ADMIX":
                    admix[sid] = bam
                else:
                    raise ValueError(
                        f"{csv_path}: unknown sample_type {stype!r} for "
                        f"sample {sid}"
                    )
        if not ref:
            raise ValueError(
                f"{csv_path} has no HOST or DONOR rows; phase 1 cannot run"
            )
        _samples_cache[patient] = (ref, admix)
    return _samples_cache[patient]


def _ref_samples(patient):
    return _patient_samples(patient)[0]


def _admix_samples(patient):
    return _patient_samples(patient)[1]


def _bam_for_sample(patient, sample):
    ref, admix = _patient_samples(patient)
    if sample in ref:
        return ref[sample]
    return admix[sample]


# Eagerly validate every CSV at parse time so errors surface up-front
# rather than mid-DAG. Also lets us decide which patients have admix work.
for _p in PATIENTS:
    _patient_samples(_p)


# Map each referenced BAM path -> sample_id, used by the optional alignment
# rule to stamp the read-group SM tag with our sample_id so the joint-call and
# admix VCFs carry sample_ids (not run accessions) as column names.
BAM_TO_SAMPLE: dict[str, str] = {}
for _p in PATIENTS:
    _ref, _admix = _patient_samples(_p)
    for _sid, _bam in {**_ref, **_admix}.items():
        BAM_TO_SAMPLE.setdefault(_bam, _sid)


def _sample_for_run(run):
    """sample_id for an aligned run, from the CSV bam_filename it produces."""
    bam = os.path.join(BAM_DIR, f"{run}.{BAM_SUFFIX}")
    try:
        return BAM_TO_SAMPLE[bam]
    except KeyError:
        raise ValueError(
            f"No CSV row references {bam}; cannot set the read-group SM tag. "
            f"Check that bam_dir ({BAM_DIR}) and bam_suffix ({BAM_SUFFIX}) match "
            f"the bam_filename paths in the patient CSVs."
        )


# ---------------------------------------------------------------------------
# Output paths (all keyed on {patient})
# ---------------------------------------------------------------------------

# Final outputs — kept at the top-level OUTPUT_DIR so existing per-patient
# VCFs from earlier single-patient runs are recognised and reused.
def _joint_vcf(patient):
    return os.path.join(OUTPUT_DIR, f"{patient}{_intervals_tag}.vcf.gz")


def _admix_vcf(patient):
    return os.path.join(OUTPUT_DIR, f"{patient}.admix.vcf.gz")


def _patient_bams(patient):
    """Distinct BAM paths for a patient (ref + admix), in stable order."""
    ref, admix = _patient_samples(patient)
    seen: list[str] = []
    for bam in {**ref, **admix}.values():
        if bam not in seen:
            seen.append(bam)
    return seen


def _ref_bams(patient):
    """Distinct HOST/DONOR BAM paths for a patient, in stable order.

    The reference-pileup phase (1b) needs the host and donor BAMs only; the
    admix BAMs carry the mixture and are not used to learn the clean background.
    """
    seen: list[str] = []
    for bam in _ref_samples(patient).values():
        if bam not in seen:
            seen.append(bam)
    return seen


# Per-patient intermediates live under <OUTPUT_DIR>/<patient>/ to avoid
# cross-patient collisions on shared filenames (combined.g.vcf.gz,
# admix/per_sample/...).
JOINT_VCF_TPL = os.path.join(OUTPUT_DIR, f"{{patient}}{_intervals_tag}.vcf.gz")
ADMIX_VCF_TPL = os.path.join(OUTPUT_DIR, "{patient}.admix.vcf.gz")
# Intermediate: the ##allomixRunUnit header fragment merged into the admix VCF.
RUN_UNITS_HDR_TPL = os.path.join(OUTPUT_DIR, "{patient}", "run_units.hdr")
GVCF_TPL = os.path.join(OUTPUT_DIR, "gvcfs", "{sample}.g.vcf.gz")
COMBINED_GVCF_TPL = os.path.join(OUTPUT_DIR, "{patient}", "combined.g.vcf.gz")
PANEL_TSV_TPL = os.path.join(OUTPUT_DIR, "{patient}", "admix", "targets.tsv.gz")
PER_SAMPLE_ADMIX_TPL = os.path.join(
    OUTPUT_DIR, "{patient}", "admix", "per_sample", "{sample}.vcf.gz"
)
# Phase 1b: raw reference-sample pileups + the derived per-patient error table.
REFS_PANEL_TPL = os.path.join(OUTPUT_DIR, "{patient}", "refs", "panel.vcf.gz")
REFS_BG_TPL = os.path.join(OUTPUT_DIR, "{patient}", "refs", "midpoints.vcf.gz")
ERROR_TABLE_TPL = os.path.join(OUTPUT_DIR, "{patient}.error_table.tsv")


def _error_table(patient):
    return os.path.join(OUTPUT_DIR, f"{patient}.error_table.tsv")


# ---------------------------------------------------------------------------
# Top-level target
# ---------------------------------------------------------------------------

def _all_targets():
    out = []
    for p in PATIENTS:
        out.append(_joint_vcf(p))
        if _admix_samples(p):
            # The admix VCF carries the run-unit header metadata (index-hopping
            # check) via its merge step, so it needs no separate target.
            out.append(_admix_vcf(p))
        # Phase 1b error table needs only HOST/DONOR BAMs, so it is built for
        # every patient (a patient always has at least one ref sample).
        if BUILD_ERROR_TABLE:
            out.append(_error_table(p))
    return out


rule all:
    input:
        _all_targets(),


# ---------------------------------------------------------------------------
# Tool validation (issue #30): check the tools.yaml executables are runnable.
# Not part of `rule all`; request it by name on a new machine:
#     snakemake -s pipeline/Snakefile validate_tools
# ---------------------------------------------------------------------------

# (executable, version-probe args). bwa has no --version flag (it prints usage
# to stderr and exits 1), so it is probed by existence only, below.
_TOOL_PROBES = {
    "gatk": (GATK, ["--version"]),
    "bcftools": (BCFTOOLS, ["--version"]),
    "samtools": (SAMTOOLS, ["--version"]),
    "tabix": (TABIX, ["--version"]),
    "bgzip": (BGZIP, ["--version"]),
    "python": (PYTHON, ["--version"]),
}
if BUILD_ERROR_TABLE:
    _TOOL_PROBES["allomix"] = (ALLOMIX, ["--version"])
# bwa is only used by the optional alignment phase; require it only then.
_EXIST_ONLY = {"bwa": BWA} if FASTQ_DIR else {}


rule validate_tools:
    """Smoke-test every configured external tool: present on PATH and runnable.

    Fails (non-zero exit) listing any tool that is missing or errors on its
    version probe, so a fresh machine's tools.yaml is verified before a real
    run. `bwa` is checked only when the alignment phase is active (fastq_dir
    set); `allomix` only when build_error_table is on.
    """
    run:
        import shutil
        import subprocess

        problems = []
        for name, exe in _EXIST_ONLY.items():
            path = shutil.which(exe)
            if path is None:
                problems.append(f"{name}: {exe!r} not found on PATH")
                print(f"MISSING  {name}: {exe!r} not found on PATH")
            else:
                print(f"OK       {name}: {exe} -> {path} (existence only)")
        for name, (exe, probe) in _TOOL_PROBES.items():
            path = shutil.which(exe)
            if path is None:
                problems.append(f"{name}: {exe!r} not found on PATH")
                print(f"MISSING  {name}: {exe!r} not found on PATH")
                continue
            try:
                res = subprocess.run(
                    [exe, *probe],
                    capture_output=True,
                    text=True,
                    timeout=120,
                )
            except (OSError, subprocess.SubprocessError) as exc:
                problems.append(f"{name}: {exe} failed to run ({exc})")
                print(f"BROKEN   {name}: {exe} failed to run ({exc})")
                continue
            if res.returncode != 0:
                err = (res.stderr or res.stdout or "").strip().splitlines()
                detail = err[0] if err else f"exit {res.returncode}"
                problems.append(f"{name}: {exe} exited {res.returncode} ({detail})")
                print(f"BROKEN   {name}: {exe} exited {res.returncode} ({detail})")
                continue
            ver = (res.stdout or res.stderr or "").strip().splitlines()
            print(f"OK       {name}: {exe} -> {ver[0] if ver else 'runnable'}")
        if problems:
            raise ValueError(
                "validate_tools found "
                f"{len(problems)} problem(s):\n  " + "\n  ".join(problems)
            )
        print("\nAll configured tools are present and runnable.")


# Restrict wildcards so {patient}/{sample} cannot match path separators
# or partial intermediate filenames (e.g. "combined.g") — otherwise
# Snakemake recurses on shared path components.
wildcard_constraints:
    patient="|".join(re.escape(p) for p in PATIENTS),
    sample=r"[^/]+",
    run=r"[^/.]+",


# ---------------------------------------------------------------------------
# Phase 0 (optional): align FASTQ -> BAM with bwa mem
# ---------------------------------------------------------------------------

if FASTQ_DIR:
    if not BAM_DIR:
        raise ValueError(
            "fastq_dir is set but bam_dir is not. Set bam_dir so the aligned "
            "BAMs land at the bam_filename paths the patient CSVs reference."
        )

    rule bwa_align:
        """Align one single-end FASTQ to a coordinate-sorted, indexed BAM.

        Optional upstream phase, present only when `fastq_dir` is configured
        (datasets that ship pre-aligned BAMs skip this entirely). The read
        group stamps SM with the sample_id from the patient CSV, so the
        phase-1 joint VCF and phase-2 admix VCF use our sample_ids as column
        names — exactly the names passed to `allomix --host-sample /
        --donor-sample / --sample`. The BAMs must not be duplicate-marked
        (amplicon/MIP panels share read start/end; dup-marking would drop
        nearly all coverage).
        """
        input:
            fastq=os.path.join(FASTQ_DIR, "{run}." + FASTQ_SUFFIX),
            ref=REF,
        output:
            bam=os.path.join(BAM_DIR, "{run}." + BAM_SUFFIX),
            bai=os.path.join(BAM_DIR, "{run}." + BAM_SUFFIX + ".bai"),
        log:
            os.path.join(OUTPUT_DIR, "logs", "bwa_align", "{run}.log"),
        threads: ALIGN_THREADS
        params:
            bwa=BWA,
            samtools=SAMTOOLS,
            sample=lambda wc: _sample_for_run(wc.run),
        shell:
            r"""
            {params.bwa} mem -t {threads} \
                -R '@RG\tID:{wildcards.run}\tSM:{params.sample}\tPL:ILLUMINA\tLB:{params.sample}' \
                {input.ref} {input.fastq} 2> {log} \
            | {params.samtools} sort -@ {threads} -o {output.bam} - 2>> {log}
            {params.samtools} index {output.bam}
            """


# ---------------------------------------------------------------------------
# Phase 1: GATK HOST + DONOR joint genotyping (per patient)
# ---------------------------------------------------------------------------

# GVCFs are keyed on sample only (sample IDs are globally unique across
# patient CSVs). This lets a sample shared between two patient CSVs reuse
# its GVCF and avoids needless reruns of cached single-patient outputs.
rule haplotype_caller:
    """Run GATK HaplotypeCaller in GVCF mode on a single HOST/DONOR sample."""
    input:
        bam=lambda wc: next(
            bam
            for p in PATIENTS
            for sid, bam in _ref_samples(p).items()
            if sid == wc.sample
        ),
        ref=REF,
    output:
        gvcf=GVCF_TPL,
        tbi=GVCF_TPL + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "haplotype_caller", "{sample}.log"),
    threads: 4
    params:
        gatk=GATK,
        tabix=TABIX,
        java_mem=JAVA_MEM,
        intervals_arg=INTERVALS_ARG,
    shell:
        """
        {params.gatk} --java-options '-Xmx{params.java_mem}' HaplotypeCaller \
            -R {input.ref} \
            -I {input.bam} \
            -ERC GVCF \
            -O {output.gvcf} \
            --native-pair-hmm-threads {threads} \
            {params.intervals_arg} \
            2>&1 | tee {log}
        {params.tabix} -f {output.gvcf}
        """


rule combine_gvcfs:
    """Merge per-sample GVCFs into a single combined GVCF for one patient.

    No -L here on purpose. The input GVCFs are already restricted to the panel
    region by haplotype_caller's -L, so CombineGVCFs needs no interval
    restriction. Passing -L here triggers a GATK bug: with a spanning or
    multiallelic <NON_REF> block straddling panel sites, the interval-restricted
    endPreviousStates flush can write records out of coordinate order ("Features
    added out of order"), which the tabix index writer rejects. genotype_gvcfs
    still applies -L + force-output, so the final panel VCF is unchanged.
    """
    input:
        gvcfs=lambda wc: expand(GVCF_TPL, sample=list(_ref_samples(wc.patient))),
        ref=REF,
    output:
        combined=COMBINED_GVCF_TPL,
        tbi=COMBINED_GVCF_TPL + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "combine_gvcfs", "{patient}.log"),
    params:
        gatk=GATK,
        tabix=TABIX,
        java_mem=JAVA_MEM,
        gvcf_args=lambda wc, input: " ".join(f"-V {g}" for g in input.gvcfs),
    shell:
        """
        {params.gatk} --java-options '-Xmx{params.java_mem}' CombineGVCFs \
            -R {input.ref} \
            {params.gvcf_args} \
            -O {output.combined} \
            2>&1 | tee {log}
        {params.tabix} -f {output.combined}
        """


rule genotype_gvcfs:
    """Joint-genotype the combined GVCF to produce one patient's panel VCF."""
    input:
        combined=COMBINED_GVCF_TPL,
        ref=REF,
    output:
        vcf=JOINT_VCF_TPL,
        tbi=JOINT_VCF_TPL + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "genotype_gvcfs", "{patient}.log"),
    params:
        gatk=GATK,
        java_mem=JAVA_MEM,
        intervals_arg=INTERVALS_ARG,
        alleles_arg=GENOTYPE_GVCFS_ALLELES_ARG,
    shell:
        """
        {params.gatk} --java-options '-Xmx{params.java_mem}' GenotypeGVCFs \
            -R {input.ref} \
            -V {input.combined} \
            -O {output.vcf} \
            --verbosity ERROR \
            {params.intervals_arg} \
            {params.alleles_arg} \
            2>&1 | tee {log}
        """


# ---------------------------------------------------------------------------
# Phase 2: forced bcftools mpileup on ADMIX samples at phase-1 panel sites
# ---------------------------------------------------------------------------

rule panel_tsv:
    """Extract (CHROM,POS,REF,ALT) targets file from one patient's panel VCF.

    Used by ``bcftools call -C alleles -T`` to force a GT at every panel
    position with the panel's exact REF/ALT pair as the only candidates.

    Drops rows where the per-patient panel has ALT="." (force-output
    sites that GATK genotyped as hom-ref in BOTH host and donor, so no
    ALT was emitted). Two reasons to drop them:
      1. ``bcftools call -A`` produces malformed PL records when the
         targets row has ``REF,.`` as the allele list.
      2. Those sites are uninformative for chimerism by construction —
         GATK saw zero ALT reads in either reference sample at >1000x,
         so host == donor == hom-ref. They cannot distinguish host from
         donor regardless of what the admix BAM shows.
    """
    input:
        vcf=JOINT_VCF_TPL,
    output:
        tsv=PANEL_TSV_TPL,
        tbi=PANEL_TSV_TPL + ".tbi",
    params:
        bcftools=BCFTOOLS,
        bgzip=BGZIP,
        tabix=TABIX,
    shell:
        """
        {params.bcftools} query -f '%CHROM\\t%POS\\t%REF,%ALT\\n' \
                -e 'ALT="."' {input.vcf} \
            | {params.bgzip} -c > {output.tsv}
        {params.tabix} -f -s1 -b2 -e2 {output.tsv}
        """


rule pileup_admix:
    """Raw pileup + constrained-allele genotyping for one admixture sample.

    ``mpileup -a FORMAT/AD,FORMAT/DP`` reports raw REF/ALT base counts at
    every panel position — no local reassembly, no minority-ALT stripping.
    ``call -m -A -C alleles -T panel_tsv`` then assigns a GT at each site
    using only the panel's known REF/ALT as candidates, so the output
    covers every panel site regardless of whether the ALT was observed.
    ``-A``/``--keep-alts`` is required: without it, ``call`` strips the
    panel's ALT to ``.`` whenever the admix sample has zero ALT reads,
    which breaks the (chrom,pos,ref,alt) join with the panel VCF
    downstream. Sites where the admix is fully host-aligned and the
    donor's panel ALT is absent are exactly the high-signal markers we
    care about for low-fraction chimerism, so the join must hold.
    """
    input:
        bam=lambda wc: _bam_for_sample(wc.patient, wc.sample),
        ref=REF,
        targets=PANEL_TSV_TPL,
        targets_tbi=PANEL_TSV_TPL + ".tbi",
        panel=JOINT_VCF_TPL,
    output:
        vcf=PER_SAMPLE_ADMIX_TPL,
        tbi=PER_SAMPLE_ADMIX_TPL + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "pileup_admix", "{patient}", "{sample}.log"),
    threads: 2
    params:
        bcftools=BCFTOOLS,
        tabix=TABIX,
        max_depth=MAX_DEPTH,
        min_mapq=MIN_MAPQ,
        min_baseq=MIN_BASEQ,
        read_filters=READ_FILTERS,
    shell:
        """
        {params.bcftools} mpileup \
            -f {input.ref} \
            -R {input.panel} \
            -a FORMAT/AD,FORMAT/DP \
            -d {params.max_depth} \
            -q {params.min_mapq} \
            -Q {params.min_baseq} \
            --ff {params.read_filters} \
            --threads {threads} \
            {input.bam} 2> {log} \
        | {params.bcftools} call \
            -m \
            -A \
            -C alleles \
            -T {input.targets} \
            -Oz -o {output.vcf} 2>> {log}
        {params.tabix} -f {output.vcf}
        """


rule merge_admix:
    """Merge per-admix-sample VCFs into one multi-sample admixture VCF per patient.

    All per-sample VCFs cover every panel site (constrained calling
    guarantees this), so the merge has no missing-sample positions.

    The merged stream is piped through ``bcftools annotate -h`` to stamp the
    ``##allomixRunUnit`` header lines (index-hopping check, issue #12) onto the
    admix VCF. The fragment is empty when no run unit was recoverable, so this is
    a no-op in that case. allomix reads the header back via ``allomix.qc.runmeta``.
    """
    input:
        vcfs=lambda wc: expand(
            PER_SAMPLE_ADMIX_TPL,
            patient=[wc.patient],
            sample=list(_admix_samples(wc.patient)),
        ),
        tbis=lambda wc: expand(
            PER_SAMPLE_ADMIX_TPL + ".tbi",
            patient=[wc.patient],
            sample=list(_admix_samples(wc.patient)),
        ),
        hdr=RUN_UNITS_HDR_TPL,
    output:
        vcf=ADMIX_VCF_TPL,
        tbi=ADMIX_VCF_TPL + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "merge_admix", "{patient}.log"),
    threads: 4
    params:
        bcftools=BCFTOOLS,
        tabix=TABIX,
    shell:
        """
        {params.bcftools} merge \
            --threads {threads} \
            --force-single \
            -m all \
            -Ou \
            {input.vcfs} 2> {log} \
        | {params.bcftools} annotate \
            -h {input.hdr} \
            --threads {threads} \
            -Oz -o {output.vcf} - 2>> {log}
        {params.tabix} -f {output.vcf}
        """


# ---------------------------------------------------------------------------
# Phase 1b (optional): per-patient empirical error table for the host-presence
# background. Raw mpileup of the HOST/DONOR BAMs (never GATK, which strips the
# minority ALT reads we are measuring) at the panel sites + amplicon midpoints,
# then `allomix estimate-errors`. See docs/joint_calling.md.
# ---------------------------------------------------------------------------

rule midpoint_bed:
    """Derive one background position per panel interval (the BED midpoint).

    The panel covers ~96 bp per amplicon but emits one polymorphic SNP, leaving
    the rest as deep, almost-always-invariant sequence. The midpoint is a clean
    hom-ref position in every individual (any that is actually polymorphic is
    dropped later by the estimator's VAF guard), so a forced raw pileup there
    measures the ref->alt error direction that the variant-only joint call
    cannot. Equivalent to scripts/make_midpoint_bed.py; inlined here to keep the
    pipeline self-contained.
    """
    input:
        bed=INTERVALS,
    output:
        bed=MIDPOINTS_BED,
    shell:
        r"""
        awk 'BEGIN{{OFS="\t"}} !/^#/ && NF>=3 {{ m=int(($2+$3)/2); print $1, m, m+1 }}' \
            {input.bed} > {output.bed}
        """


rule pileup_refs_panel:
    """Raw pileup of every HOST/DONOR BAM at the panel sites (one multi-sample VCF).

    Mirrors the admix pileup (``mpileup -a AD,DP`` + ``call -m -A -C alleles -T``)
    but on the reference BAMs, so the per-site AD carries the real REF/ALT read
    counts GATK strips. A reference sample that is hom-ref at a panel site gives
    the ref->alt rate there; one that is hom-alt gives alt->ref.
    """
    input:
        bams=lambda wc: _ref_bams(wc.patient),
        ref=REF,
        targets=PANEL_TSV_TPL,
        targets_tbi=PANEL_TSV_TPL + ".tbi",
        panel=JOINT_VCF_TPL,
    output:
        vcf=REFS_PANEL_TPL,
        tbi=REFS_PANEL_TPL + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "pileup_refs_panel", "{patient}.log"),
    threads: 2
    params:
        bcftools=BCFTOOLS,
        tabix=TABIX,
        max_depth=MAX_DEPTH,
        min_mapq=MIN_MAPQ,
        min_baseq=MIN_BASEQ,
        read_filters=READ_FILTERS,
    shell:
        """
        {params.bcftools} mpileup \
            -f {input.ref} \
            -R {input.panel} \
            -a FORMAT/AD,FORMAT/DP \
            -d {params.max_depth} \
            -q {params.min_mapq} \
            -Q {params.min_baseq} \
            --ff {params.read_filters} \
            --threads {threads} \
            {input.bams} 2> {log} \
        | {params.bcftools} call \
            -m \
            -A \
            -C alleles \
            -T {input.targets} \
            -Oz -o {output.vcf} 2>> {log}
        {params.tabix} -f {output.vcf}
        """


rule pileup_refs_bg:
    """Raw pileup of every HOST/DONOR BAM at the amplicon-midpoint background sites.

    No ``-C alleles``: midpoints have no known panel ALT, so ``call -m -A``
    discovers whichever stray base appears and keeps it, leaving a 0/0 call with
    the few error reads in AD. ``estimate-errors`` reads those as the ref->alt
    direction. Almost every midpoint is hom-ref in every individual; the rare
    polymorphic one is dropped by ``--max-vaf-homref``.
    """
    input:
        bams=lambda wc: _ref_bams(wc.patient),
        ref=REF,
        midpoints=MIDPOINTS_BED,
    output:
        vcf=REFS_BG_TPL,
        tbi=REFS_BG_TPL + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "pileup_refs_bg", "{patient}.log"),
    threads: 2
    params:
        bcftools=BCFTOOLS,
        tabix=TABIX,
        max_depth=MAX_DEPTH,
        min_mapq=MIN_MAPQ,
        min_baseq=MIN_BASEQ,
        read_filters=READ_FILTERS,
    shell:
        """
        {params.bcftools} mpileup \
            -f {input.ref} \
            -R {input.midpoints} \
            -a FORMAT/AD,FORMAT/DP \
            -d {params.max_depth} \
            -q {params.min_mapq} \
            -Q {params.min_baseq} \
            --ff {params.read_filters} \
            --threads {threads} \
            {input.bams} 2> {log} \
        | {params.bcftools} call \
            -m \
            -A \
            -Oz -o {output.vcf} 2>> {log}
        {params.tabix} -f {output.vcf}
        """


rule error_table:
    """Per-patient, per-site, both-direction error table for the host-presence
    background. Pools the panel pileup (both directions) with the midpoint
    pileup (ref->alt) across the HOST/DONOR samples.
    """
    input:
        panel=REFS_PANEL_TPL,
        homref=REFS_BG_TPL,
    output:
        tsv=ERROR_TABLE_TPL,
    log:
        os.path.join(OUTPUT_DIR, "logs", "error_table", "{patient}.log"),
    params:
        allomix=ALLOMIX,
        sample_flags=lambda wc: " ".join(f"--sample {s}" for s in _ref_samples(wc.patient)),
    shell:
        """
        {params.allomix} estimate-errors \
            {input.panel} \
            --homref-vcf {input.homref} \
            {params.sample_flags} \
            -o {output.tsv} \
            2>&1 | tee {log}
        """


# ---------------------------------------------------------------------------
# Run-unit metadata: index-hopping check (issue #12)
# ---------------------------------------------------------------------------

rule run_units_header:
    """Build the ##allomixRunUnit header fragment for one patient's admix samples.

    allomix is VCF-first and never opens a BAM, so the flowcell identity an
    index-hopping flag needs is read here and written as VCF header lines that
    ``merge_admix`` stamps onto the admix VCF. Index hopping leaks reads between
    samples clustered in the same flowcell lane, so a host sharing a run unit
    with an admixture sample can deposit hopped host reads into it and fake a
    host-presence signal. One ``##allomixRunUnit`` line per admix sample records
    its run unit and whether it shares one with the host. On SRA-derived BAMs the
    run unit is unrecoverable (renamed reads, no PU tag): such samples get no
    line, and an all-unknown patient yields an empty fragment, so the flag stays
    silent rather than reporting a false "no risk". See
    ``pipeline/scripts/extract_run_units.py``.
    """
    input:
        bams=lambda wc: _patient_bams(wc.patient),
        csv=lambda wc: PATIENTS[wc.patient],
        script=os.path.join(workflow.basedir, "scripts", "extract_run_units.py"),
    output:
        hdr=RUN_UNITS_HDR_TPL,
    log:
        os.path.join(OUTPUT_DIR, "logs", "run_units_header", "{patient}.log"),
    params:
        python=PYTHON,
        samtools=SAMTOOLS,
    shell:
        """
        {params.python} {input.script} \
            --csv {input.csv} \
            --out {output.hdr} \
            --samtools {params.samtools} \
            2>&1 | tee {log}
        """


# ---------------------------------------------------------------------------
# Cleanup
# ---------------------------------------------------------------------------

rule clean:
    """Remove all pipeline output."""
    shell:
        f"rm -rf {OUTPUT_DIR}/"
