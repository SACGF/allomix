"""Per-patient genotyping + admixture pileup pipeline for allomix.

One CSV per patient with columns ``sample_id,bam_filename,sample_type``
(values ``HOST``, ``DONOR``, ``ADMIX``). Pipeline runs in two phases that
share a single DAG:

    Phase 1 — GATK joint-call HOST + DONOR BAMs
        HaplotypeCaller (GVCF) -> CombineGVCFs -> GenotypeGVCFs
        Output: <patient>.vcf.gz  (panel sites + reliable host/donor GTs)

    Phase 2 — Forced bcftools mpileup on ADMIX BAMs at the phase-1 sites
        Per admix sample: bcftools mpileup -a FORMAT/AD,FORMAT/DP -R panel
                          | bcftools call -m -C alleles -T panel.targets
        Then bcftools merge across admix samples.
        Output: <patient>.admix.vcf.gz  (raw AD at every panel site)

Why this split: GATK is the right tool for genotyping the reference
samples (we only need GT there). It is the wrong tool for the admix AD,
because HaplotypeCaller -ERC GVCF strips minority ALT reads from
FORMAT/AD at hom-ref blocks (local reassembly only tracks the called
allele). That is exactly the signal that low-fraction host detection
depends on. ``bcftools mpileup`` preserves raw per-allele counts;
``bcftools call -C alleles`` then assigns a GT at every panel site
using only the panel's known REF/ALT pair as candidates.

One patient per CSV: joint-calling across patients adds samples to the
VCF with no informative markers for each other and just inflates run
time. Also matches the GMP constraint of explicit host/donor pairing.

Usage (from repo root):
    snakemake -s pipeline/Snakefile --configfile pipeline/config.yaml --cores 8
    snakemake -s pipeline/Snakefile \\
        --config ref=/path/hg38.fa samples_csv=patientX.csv --cores 8
"""

import csv
import os


# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

configfile: os.path.join(workflow.basedir, "config.yaml")

REF = config["ref"]
SAMPLES_CSV = config["samples_csv"]
OUTPUT_DIR = config.get("output_dir", "output/joint_call")

# Phase 1 (GATK)
GATK = config.get("gatk", "gatk")
JAVA_MEM = config.get("java_mem", "8g")
INTERVALS = config.get("intervals", None)
INTERVALS_ARG = f"-L {INTERVALS}" if INTERVALS else ""
_intervals_tag = f".{os.path.splitext(os.path.basename(INTERVALS))[0]}" if INTERVALS else ""

# Phase 2 (bcftools mpileup)
BCFTOOLS = config.get("bcftools", "bcftools")
MAX_DEPTH = config.get("max_depth", 100000)
MIN_MAPQ = config.get("min_mapq", 20)
MIN_BASEQ = config.get("min_baseq", 20)
READ_FILTERS = config.get("read_filters", "UNMAP,SECONDARY,QCFAIL,DUP")

# Shared
TABIX = config.get("tabix", "tabix")

OUTPUT_PREFIX = config.get("output_prefix", os.path.splitext(os.path.basename(SAMPLES_CSV))[0])

# Phase 1 paths
GVCF_DIR = os.path.join(OUTPUT_DIR, "gvcfs")
JOINT_VCF = os.path.join(OUTPUT_DIR, f"{OUTPUT_PREFIX}{_intervals_tag}.vcf.gz")

# Phase 2 paths
ADMIX_DIR = os.path.join(OUTPUT_DIR, "admix")
PANEL_TSV = os.path.join(ADMIX_DIR, f"{OUTPUT_PREFIX}.targets.tsv.gz")
ADMIX_VCF = os.path.join(OUTPUT_DIR, f"{OUTPUT_PREFIX}.admix.vcf.gz")


def load_samples(csv_path, allowed_types):
    """Read sample_id -> bam_filename, filtered by sample_type column.

    The CSV must declare a ``sample_type`` per row. Returns an empty dict
    if the CSV has no rows matching ``allowed_types`` (e.g. a pre-transplant
    CSV with no ADMIX timepoints yet) — phase 2 will then have nothing to do.
    """
    samples = {}
    with open(csv_path) as f:
        reader = csv.DictReader(f)
        if "sample_type" not in (reader.fieldnames or []):
            raise ValueError(
                f"{csv_path} is missing the required 'sample_type' column "
                f"(expected values: HOST, DONOR, ADMIX)"
            )
        for row in reader:
            stype = row["sample_type"].strip().upper()
            if stype in allowed_types:
                samples[row["sample_id"]] = row["bam_filename"]
    return samples


REF_SAMPLES = load_samples(SAMPLES_CSV, allowed_types={"HOST", "DONOR"})
ADMIX_SAMPLES = load_samples(SAMPLES_CSV, allowed_types={"ADMIX"})

if not REF_SAMPLES:
    raise ValueError(
        f"{SAMPLES_CSV} has no HOST or DONOR rows; phase 1 has nothing to call"
    )


# ---------------------------------------------------------------------------
# Top-level target
# ---------------------------------------------------------------------------

# Build the admix VCF when admix samples exist; otherwise just the panel VCF.
_targets = [JOINT_VCF]
if ADMIX_SAMPLES:
    _targets.append(ADMIX_VCF)


rule all:
    input:
        _targets,


# ---------------------------------------------------------------------------
# Phase 1: GATK HOST + DONOR joint genotyping
# ---------------------------------------------------------------------------

rule haplotype_caller:
    """Run GATK HaplotypeCaller in GVCF mode on a single HOST/DONOR sample."""
    input:
        bam=lambda wc: REF_SAMPLES[wc.sample],
        ref=REF,
    output:
        gvcf=os.path.join(GVCF_DIR, "{sample}.g.vcf.gz"),
        tbi=os.path.join(GVCF_DIR, "{sample}.g.vcf.gz.tbi"),
    log:
        os.path.join(OUTPUT_DIR, "logs", "haplotype_caller", "{sample}.log"),
    threads: 4
    params:
        gatk=GATK,
        tabix=TABIX,
        java_mem=JAVA_MEM,
        intervals_arg=INTERVALS_ARG,
    shell:
        """
        {params.gatk} --java-options '-Xmx{params.java_mem}' HaplotypeCaller \
            -R {input.ref} \
            -I {input.bam} \
            -ERC GVCF \
            -O {output.gvcf} \
            --native-pair-hmm-threads {threads} \
            {params.intervals_arg} \
            2>&1 | tee {log}
        {params.tabix} -f {output.gvcf}
        """


rule combine_gvcfs:
    """Merge per-sample GVCFs into a single combined GVCF."""
    input:
        gvcfs=expand(os.path.join(GVCF_DIR, "{sample}.g.vcf.gz"), sample=REF_SAMPLES),
        ref=REF,
    output:
        combined=os.path.join(OUTPUT_DIR, "combined.g.vcf.gz"),
        tbi=os.path.join(OUTPUT_DIR, "combined.g.vcf.gz.tbi"),
    log:
        os.path.join(OUTPUT_DIR, "logs", "combine_gvcfs.log"),
    params:
        gatk=GATK,
        tabix=TABIX,
        java_mem=JAVA_MEM,
        intervals_arg=INTERVALS_ARG,
        gvcf_args=lambda wc, input: " ".join(f"-V {g}" for g in input.gvcfs),
    shell:
        """
        {params.gatk} --java-options '-Xmx{params.java_mem}' CombineGVCFs \
            -R {input.ref} \
            {params.gvcf_args} \
            -O {output.combined} \
            {params.intervals_arg} \
            2>&1 | tee {log}
        {params.tabix} -f {output.combined}
        """


rule genotype_gvcfs:
    """Joint-genotype the combined GVCF to produce the panel VCF."""
    input:
        combined=os.path.join(OUTPUT_DIR, "combined.g.vcf.gz"),
        ref=REF,
    output:
        vcf=JOINT_VCF,
        tbi=JOINT_VCF + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "genotype_gvcfs.log"),
    params:
        gatk=GATK,
        java_mem=JAVA_MEM,
        intervals_arg=INTERVALS_ARG,
    shell:
        """
        {params.gatk} --java-options '-Xmx{params.java_mem}' GenotypeGVCFs \
            -R {input.ref} \
            -V {input.combined} \
            -O {output.vcf} \
            --verbosity ERROR \
            {params.intervals_arg} \
            2>&1 | tee {log}
        """


# ---------------------------------------------------------------------------
# Phase 2: forced bcftools mpileup on ADMIX samples at phase-1 panel sites
# ---------------------------------------------------------------------------

rule panel_tsv:
    """Extract (CHROM,POS,REF,ALT) targets file from the phase-1 panel VCF.

    Used by ``bcftools call -C alleles -T`` to force a GT at every panel
    position with the panel's exact REF/ALT pair as the only candidates.
    """
    input:
        vcf=JOINT_VCF,
    output:
        tsv=PANEL_TSV,
        tbi=PANEL_TSV + ".tbi",
    params:
        bcftools=BCFTOOLS,
        tabix=TABIX,
    shell:
        """
        {params.bcftools} query -f '%CHROM\\t%POS\\t%REF,%ALT\\n' {input.vcf} \
            | bgzip -c > {output.tsv}
        {params.tabix} -f -s1 -b2 -e2 {output.tsv}
        """


rule pileup_admix:
    """Raw pileup + constrained-allele genotyping for one admixture sample.

    ``mpileup -a FORMAT/AD,FORMAT/DP`` reports raw REF/ALT base counts at
    every panel position — no local reassembly, no minority-ALT stripping.
    ``call -m -C alleles -T panel_tsv`` then assigns a GT at each site
    using only the panel's known REF/ALT as candidates, so the output
    covers every panel site regardless of whether the ALT was observed.
    """
    input:
        bam=lambda wc: ADMIX_SAMPLES[wc.sample],
        ref=REF,
        targets=PANEL_TSV,
        targets_tbi=PANEL_TSV + ".tbi",
        panel=JOINT_VCF,
    output:
        vcf=os.path.join(ADMIX_DIR, "per_sample", "{sample}.vcf.gz"),
        tbi=os.path.join(ADMIX_DIR, "per_sample", "{sample}.vcf.gz.tbi"),
    log:
        os.path.join(OUTPUT_DIR, "logs", "pileup_admix", "{sample}.log"),
    threads: 2
    params:
        bcftools=BCFTOOLS,
        tabix=TABIX,
        max_depth=MAX_DEPTH,
        min_mapq=MIN_MAPQ,
        min_baseq=MIN_BASEQ,
        read_filters=READ_FILTERS,
    shell:
        """
        {params.bcftools} mpileup \
            -f {input.ref} \
            -R {input.panel} \
            -a FORMAT/AD,FORMAT/DP \
            -d {params.max_depth} \
            -q {params.min_mapq} \
            -Q {params.min_baseq} \
            --ff {params.read_filters} \
            --threads {threads} \
            {input.bam} 2> {log} \
        | {params.bcftools} call \
            -m \
            -C alleles \
            -T {input.targets} \
            -Oz -o {output.vcf} 2>> {log}
        {params.tabix} -f {output.vcf}
        """


rule merge_admix:
    """Merge per-admix-sample VCFs into one multi-sample admixture VCF.

    All per-sample VCFs cover every panel site (constrained calling
    guarantees this), so the merge has no missing-sample positions.
    """
    input:
        vcfs=expand(
            os.path.join(ADMIX_DIR, "per_sample", "{sample}.vcf.gz"),
            sample=ADMIX_SAMPLES,
        ),
        tbis=expand(
            os.path.join(ADMIX_DIR, "per_sample", "{sample}.vcf.gz.tbi"),
            sample=ADMIX_SAMPLES,
        ),
    output:
        vcf=ADMIX_VCF,
        tbi=ADMIX_VCF + ".tbi",
    log:
        os.path.join(OUTPUT_DIR, "logs", "merge_admix.log"),
    threads: 4
    params:
        bcftools=BCFTOOLS,
        tabix=TABIX,
    shell:
        """
        {params.bcftools} merge \
            --threads {threads} \
            -m all \
            -Oz -o {output.vcf} \
            {input.vcfs} 2>&1 | tee {log}
        {params.tabix} -f {output.vcf}
        """


# ---------------------------------------------------------------------------
# Cleanup
# ---------------------------------------------------------------------------

rule clean:
    """Remove all pipeline output."""
    shell:
        f"rm -rf {GVCF_DIR}/ {OUTPUT_DIR}/combined.g.vcf.gz* "
        f"{JOINT_VCF}* {ADMIX_DIR}/ {ADMIX_VCF}* {OUTPUT_DIR}/logs/"
